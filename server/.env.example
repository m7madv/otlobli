# قالب متغيّرات بيئة سيرفر الواتساب — انسخه إلى .env واملأ القيم.
# القيم الحقيقية موجودة في متغيّرات Railway الحالية (Service → Variables).
# لا ترفع ملف .env الحقيقي إلى Git أبداً (يحوي أسراراً).

# المنفذ الذي يستمع عليه السيرفر
PORT=3001

# Supabase (قاعدة البيانات)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# لوحة الإدارة
ADMIN_PIN=
ADMIN_URL=

# سرّ توقيع إشعارات الطلبات
ORDER_NOTIFY_SECRET=

# تيليجرام (إشعارات)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# سعر افتراضي احتياطي فقط (المصدر الحقيقي صار مهمة GitHub Actions)
VITE_USD_TO_SYP_RATE=13000

# مكافحة الحظر: الفاصل الأدنى بالمللي ثانية بين أي رسالتين واتساب.
# الافتراضي 4000. زِدها (مثلاً 6000) لأمان أكبر ضد الحظر مقابل إرسال أبطأ.
WHATSAPP_MIN_SEND_GAP_MS=4000

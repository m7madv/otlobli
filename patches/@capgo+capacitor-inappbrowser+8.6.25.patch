+    private func emitPageLoadError(_ webView: WKWebView?, error: Error?, phase: String) {
+        var data: [String: Any] = ["phase": phase]
+
+        if let error = error {
+            let nsError = error as NSError
+            data["domain"] = nsError.domain
+            data["code"] = nsError.code
+            data["description"] = nsError.localizedDescription
+
+            if let failingUrl = nsError.userInfo[NSURLErrorFailingURLErrorKey] as? URL {
+                data["url"] = failingUrl.absoluteString
+            }
+            if let failingUrlString = nsError.userInfo[NSURLErrorFailingURLStringErrorKey] as? String {
+                data["failingUrlString"] = failingUrlString
+                if data["url"] == nil {
+                    data["url"] = failingUrlString
+                }
+            }
+        }
+
+        if data["url"] == nil {
+            if let currentUrl = webView?.url {
+                data["url"] = currentUrl.absoluteString
+            } else if let currentUrl = self.url {
+                data["url"] = currentUrl.absoluteString
+            }
+        }
+
+        emit("pageLoadError", data: data)
+    }
